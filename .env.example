# ─────────────────────────────────────────────
#  Prométhée AI Desktop — Configuration
# ─────────────────────────────────────────────

# ── Application ───────────────────────────
APP_TITLE=Prométhée
APP_USER=Pierre


# Nombre maximum de conversation historisées affichées
SIDEBAR_MAX_CONVERSATIONS=15

# Base de données de l'historique des conversations
HISTORY_DB=history.db


# ── Chiffrement de la base SQLite ────────────
# DB_ENCRYPTION=ON  → les conversations sont chiffrées sur disque
# DB_ENCRYPTION=OFF → comportement par défaut, aucun chiffrement (défaut)
#
# Au premier lancement avec ON, une fenêtre vous demande de créer une passphrase.
# Aux lancements suivants, cette passphrase sera demandée à chaque démarrage.
# ATTENTION : aucun mécanisme de récupération en cas d'oubli.
DB_ENCRYPTION=OFF

# DB_ENCRYPTION_SEARCH=ON  → recherche fonctionnelle (FTS5 en clair, compromis)
# DB_ENCRYPTION_SEARCH=OFF → sécurité maximale, recherche désactivée
# Ignoré si DB_ENCRYPTION=OFF.
DB_ENCRYPTION_SEARCH=ON




# ──── GESTION DU CONTEXTE ────────────────────
# Consolidation périodique : résumé LLM généré tous les N tours agent.
CONTEXT_CONSOLIDATION_EVERY=8      # 0 pour désactiver

# Taille max du résumé de consolidation injecté en contexte (caractères).
CONTEXT_CONSOLIDATION_MAX_CHARS=3000

# Marquage des tool_results critiques (cités dans la réponse assistant).
# ON = protège les résultats cités contre la compression mécanique.
CONTEXT_PINNING_ENABLED=ON


# Consolidation adaptative : déclenche une consolidation dès que la pression
# sur le contexte dépasse ce seuil (ratio prompt_tokens / CONTEXT_MODEL_MAX_TOKENS).
# 0.0 = désactivé (seulement la fréquence fixe).
# Recommandé : 0.70 (consolidation à 70% de la fenêtre occupée)
CONTEXT_CONSOLIDATION_PRESSURE_THRESHOLD=0.70


# ── Fenêtre de contexte ────────────────────────────────────────────────────────
# Taille maximale de la fenêtre de contexte du modèle (tokens).
CONTEXT_MODEL_MAX_TOKENS=128000

# Taille max de l'historique entrant (tokens réels). 0 = désactivé.
CONTEXT_HISTORY_MAX_TOKENS=90000

# Fallback en caractères si les tokens réels ne sont pas encore connus.
CONTEXT_HISTORY_MAX_CHARS=400000

# Compression des tool_results : après combien de tours agent. 0 = désactivé.
CONTEXT_AGENT_COMPRESS_AFTER=6

# Taille max d'un tool_result condensé (caractères).
CONTEXT_TOOL_RESULT_SUMMARY_CHARS=4000

# Taille max de la réponse générée par le LLM (tokens).
MAX_CONTEXT_TOKENS=12000


# ── Data Gouv (datagouv_tools) ───────────────────────
# URL du serveur MCP public de l'État (Streamable HTTP, pas de clé API requise)
DATAGOUV_MCP_URL=https://mcp.data.gouv.fr/mcp
# Timeout en secondes pour les appels au serveur MCP
DATAGOUV_MCP_TIMEOUT=30


# ── Mode de fonctionnement────────────────────────────
# Mode : ON = Ollama local / OFF = serveur OpenAI-compatible (Albert)
LOCAL='OFF'
OPENAI_API_BASE='https://albert.api.etalab.gouv.fr/v1'
OPENAI_API_KEY='sk-*****'
OPENAI_MODEL='openai/gpt-oss-120b'
OLLAMA_BASE_URL='http://localhost:11434'
OLLAMA_MODEL='nemotron-3-nano:latest'


# Identifiants OAuth PISTE
# Obtenez-les sur https://piste.gouv.fr après inscription
OAUTH_CLIENT_ID=********
OAUTH_CLIENT_SECRET=*************

LEGIFRANCE_CLIENT_ID=*************
LEGIFRANCE_CLIENT_SECRET=************

JUDILIBRE_CLIENT_ID=*************
JUDILIBRE_CLIENT_SECRET=******************


# URLs de l'API Légifrance
LEGIFRANCE_OAUTH_URL=https://oauth.piste.gouv.fr/api/oauth/token
LEGIFRANCE_API_URL=https://api.piste.gouv.fr/dila/legifrance/lf-engine-app


# ── Qdrant (base vectorielle locale) ──
QDRANT_URL='http://localhost:6333'
QDRANT_COLLECTION='Prométhée'

# ── Embeddings ────────────────────────────
# Mode: "local" (sentence-transformers) ou "api" (OpenAI-compatible)
EMBEDDING_MODE='api'
EMBEDDING_MODEL='BAAI/bge-m3'

# URL de l'API d'embeddings (si EMBEDDING_MODE=api)
EMBEDDING_API_BASE='https://albert.api.etalab.gouv.fr/v1'

# Dimension des vecteurs
EMBEDDING_DIMENSION='1024'


# ── Thunderbird ───────────────────────────
# Chemin absolu vers le profil Thunderbird (optionnel).
# Si vide, la détection automatique est utilisée.
# Exemple : /home/user/.thunderbird/abc12345.default-release
TB_PROFILE_PATH=


# ── Recherche web (web_search_tools) ──────────────────────────────────────────
# Moteur de recherche : "ddg" (DuckDuckGo, défaut) ou "searxng" (auto-hébergé)
WEB_SEARCH_ENGINE=ddg
# URL de l'instance SearXNG (requis uniquement si WEB_SEARCH_ENGINE=searxng)
# WEB_SEARCH_SEARXNG_URL=http://localhost:8080
# Langue par défaut des résultats
WEB_SEARCH_DEFAULT_LANG=fr-FR

# ── OCR (ocr_tools) ───────────────────────────────────────────────────────────
# Langues Tesseract par défaut (plusieurs langues séparées par +)
OCR_DEFAULT_LANG=fra+eng
# Nombre maximum de pages PDF à traiter par appel
OCR_MAX_PAGES=50


